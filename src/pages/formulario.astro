---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Registro — Únete al Club Hello World">
  <section aria-labelledby="form-titulo" class="min-h-screen pt-32 pb-20 bg-[#020617] flex items-center justify-center px-4">
    <div class="max-w-3xl w-full bg-[#111827]/50 border border-gray-800 p-8 md:p-12 rounded-3xl shadow-2xl backdrop-blur-sm">
      
      <div class="text-center mb-10">
        <h1 id="form-titulo" class="text-3xl md:text-4xl font-bold text-white mb-2">Formulario de Registro</h1>
        <p class="text-gray-300">Completa tus datos para formar parte de nuestra comunidad</p>
      </div>

      <form action="#" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6" novalidate>
        
        <div class="flex flex-col gap-2">
          <label for="f-nombres" class="text-sm font-medium text-blue-300 ml-1">
            Nombre(s) <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-nombres" type="text" name="nombres" required autocomplete="given-name"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all placeholder-gray-500"
            placeholder="Tu nombre">
        </div>

        <div class="flex flex-col gap-2">
          <label for="f-apellidos" class="text-sm font-medium text-blue-300 ml-1">
            Apellidos <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-apellidos" type="text" name="apellidos" required autocomplete="family-name"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all placeholder-gray-500"
            placeholder="Tus apellidos">
        </div>

        <div class="flex flex-col gap-2">
          <label for="f-cuenta" class="text-sm font-medium text-blue-300 ml-1">
            Número de cuenta <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-cuenta" type="text" name="cuenta" required inputmode="numeric"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 transition-all placeholder-gray-500"
            placeholder="000000000" pattern="[0-9]{9}">
        </div>

        <div class="flex flex-col gap-2">
          <label for="f-carrera" class="text-sm font-medium text-blue-300 ml-1">
            Carrera <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <select id="f-carrera" name="carrera" required
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 transition-all">
            <option value="" disabled selected>Selecciona tu carrera</option>
            <option value="computacion">Ingeniería en Computación</option>
            <option value="civil">Ingeniería Civil</option>
            <option value="industrial">Ingeniería Industrial</option>
            <option value="mecanica">Ingeniería Mecánica</option>
            <option value="electrica">Ingeniería Eléctrica Electrónica</option>
            <option value="derecho">Derecho</option>
            <option value="comunicacion">Comunicación y Periodismo</option>
            <option value="economia">Economía</option>
            <option value="relaciones">Relaciones Internacionales</option>
            <option value="agropecuario">Planificación para el Desarrollo Agropecuario</option>
            <option value="arquitectura">Arquitectura</option>
            <option value="disenio">Diseño Industrial</option>
            <option value="pedagogia">Pedagogía</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="f-correo-inst" class="text-sm font-medium text-blue-300 ml-1">
            Correo institucional <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-correo-inst" type="email" name="correo_inst" required autocomplete="email"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 transition-all placeholder-gray-500"
            placeholder="usuario@aragon.unam.mx"
            pattern="^[a-zA-Z0-9._%+\-]+@aragon\.unam\.mx$">
        </div>

        <div class="flex flex-col gap-2">
          <label for="f-correo-pers" class="text-sm font-medium text-blue-300 ml-1">
            Correo personal <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-correo-pers" type="email" name="correo_pers" required autocomplete="email"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 transition-all placeholder-gray-500"
            placeholder="correo@ejemplo.com">
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label for="f-contacto" class="text-sm font-medium text-blue-300 ml-1">
            Número de contacto (WhatsApp) <span class="text-red-400" aria-hidden="true">*</span>
          </label>
          <input id="f-contacto" type="tel" name="contacto" required autocomplete="tel" inputmode="numeric"
            class="bg-[#0a0f1a] border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 transition-all placeholder-gray-500"
            placeholder="10 dígitos" pattern="^[0-9]{10}$">
        </div>

        <div class="md:col-span-2 mt-4">
          <button type="submit"
            class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-900/20 transition-all transform hover:scale-[1.01] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-[#020617]">
            Enviar Registro →
          </button>
        </div>
      </form>

    </div>
  </section>
</Layout>