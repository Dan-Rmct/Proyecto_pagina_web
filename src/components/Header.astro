<header id="navbar" class="fixed top-0 w-full transition-all duration-300">
    <nav class="max-w 7xl mx-auto flex items-center justify-between p-4">

        <!--Logo -->
        <a href="/" class="flex items-center">
            <img src="/Logo completo.png" alt="Hello world logo" class="h-20">
        </a>

        <!--Navegación -->
        <ul class="hidden md:flex gap-8 text-black font-medium">
            <li><a href="#">Inicio</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Proyectos</a></li>
            <li><a href="#">Eventos</a></li>
            <li><a href="#">Equipo</a></li>
            <li><a href="#">Contacto</a></li>
        </ul>

        <!-- Botón Únete -->
        <a href="#" class="hidden md:block bg-[#5741A6] px-4 py-2 rounded-lg text-white hover:bg-[#55468C] transition">
        Únete ahora
        </a>

        <!--Boton moviles -->
        <button id="menu-btn" class="md:hidden text-white text-2xl"> 
        ☰
        </button>

        </nav>

        <!--Menu para moviles -->
        <div id="mobile-menu" class="hidden md:hidden bg-[#163a59] text-white">

        <ul class="flex flex-col items-center gap-6 py-6">
            <li><a href="#">Inicio</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Proyectos</a></li>
            <li><a href="#">Eventos</a></li>
            <li><a href="#">Equipo</a></li>
            <li><a href="#">Contacto</a></li>
            <li>
            <a href="#" class="bg-[#5741A6] px-4 py-2 rounded-lg">
            Únete ahora
            </a>
            </li>
        </ul>

        </div>

</header>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const navbar = document.getElementById("navbar");
    const menuBtn =document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu")

    window.addEventListener("scroll", () => {
        if(!navbar) return;

        if(window.scrollY > 50) {
            navbar.classList.add("bg-[#163a59]/90","backdrop-blur-md","shadow-lg");
        }else{
            navbar.classList.remove("bg-[#163a59]/90","backdrop-blur-md","shadow-lg");
        }
    });

    menuBtn?.addEventListener("click", () =>{
    mobileMenu?.classList.toggle("hidden");
    });
});
</script>
