---
<div class="flex flex-col w-full">
  <div class="px-32 mb-20">
    <div class="inline-flex gap-6 bg-[#111827]/50 p-4 rounded-2xl border border-white/5 backdrop-blur-sm"></div>
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 rounded-full bg-purple-500 shadow-[0_0_8px_rgba(168,85,247,0.4)]"></div>
        <span class="text-gray-400 text-[10px] font-bold uppercase tracking-widest">Límite de registro</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.4)]"></div>
        <span class="text-gray-400 text-[10px] font-bold uppercase tracking-widest">Día del evento</span>
      </div>
    </div>
  </div>

  <div class="relative flex items-center min-h-[800px] overflow-x-auto scrollbar-hide px-32 py-60 pb-20">  

      {meses.map((mes, idx) => {
        const esArriba = idx % 2 !== 0; 
        
        return (
          <div class="relative flex flex-col items-center flex-shrink-0 mx-24">
            <div class={`absolute flex flex-col items-center w-72 ${esArriba ? 'bottom-1/2 pb-8' : 'top-1/2 pt-8'}`}>
              
              {/* nombre del mes*/}
              <h3 class={`text-white font-black text-2xl tracking-tighter mb-4 ${esArriba ? 'order-last mt-4' : 'order-first mb-4'}`}>
                {mes.nombre}
              </h3>

              {/* línea derivada del mes*/}
              <div class={`w-px bg-gray-700 h-16 ${esArriba ? 'order-2' : 'order-2'}`}></div>

              {/* eventos de menor a mayor fecha*/}
              <div class={`flex flex-col gap-6 ${esArriba ? 'order-first flex-col-reverse' : 'order-last mt-6'}`}>
                {mes.eventos.map((ev, evIdx) => (
                  <div class="flex items-center gap-4 relative group">
                    <span class="text-gray-500 font-mono text-lg w-6 text-right">{ev.dia}</span>
                    
                    <button 
                      class={`text-sm font-bold border-b-2 py-1 transition-all hover:scale-105 event-trigger cursor-pointer whitespace-nowrap ${ev.tipo === 'registro' ? 'text-purple-400 border-purple-500/30' : 'text-cyan-400 border-cyan-500/30'}`}
                      data-target={`modal-${idx}-${evIdx}`}
                    >
                      {ev.titulo}
                    </button>

                    <div 
                      id={`modal-${idx}-${evIdx}`}
                      class="absolute left-full ml-6 w-72 bg-[#111827]/95 backdrop-blur-xl border border-gray-700 p-6 rounded-[2.5rem] shadow-2xl opacity-0 pointer-events-none transition-all transform translate-x-4 z-50 info-cloud"
                    >

                      <h4 class="text-white font-bold text-lg mb-1">{ev.titulo}</h4>
                      <p class="text-cyan-400 text-[11px] font-semibold mb-1">🕒 {ev.hora} hrs</p>
                      <a href={ev.lugarUrl} target="_blank" class="text-gray-400 text-[10px] block mb-3 hover:text-white flex items-center gap-1">
                        📍 <span class="underline decoration-gray-700">{ev.lugar}</span>
                      </a>
                      <div class="bg-[#0a0f1a] p-4 rounded-2xl mb-5 border border-gray-800">
                        <p class="text-gray-400 text-[10px] italic leading-relaxed">"{ev.desc}"</p>
                      </div>
                      <div class="flex flex-col gap-2">
                        <a href={ev.link} target="_blank" class="w-full bg-blue-600 text-white text-center py-2.5 rounded-xl text-[10px] font-bold hover:bg-blue-500 transition-all">Registrarme</a>
                        <a href={`https://www.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(ev.titulo)}&dates=${ev.fechaISO}&details=${encodeURIComponent(ev.desc)}&location=${encodeURIComponent(ev.lugar)}`} target="_blank" class="w-full border border-gray-700 text-gray-400 py-2.5 rounded-xl text-[9px] text-center hover:bg-white/5 transition-all">+ Agregar a Google Calendar</a>
                      </div>
                      <div class="absolute right-full top-6 w-0 h-0 border-t-[8px] border-t-transparent border-b-[8px] border-b-transparent border-r-[8px] border-r-[#111827]"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="w-10 h-10 rounded-full border-2 border-gray-700 bg-[#020617] z-20 flex items-center justify-center">
              <div class="w-2 h-2 bg-gray-700 rounded-full shadow-[0_0_10px_rgba(255,255,255,0.2)]"></div>
            </div>

          </div>
        )
      })}
    </div>
  </section>

<script>
  const buttons = document.querySelectorAll('.event-trigger');
  const clouds = document.querySelectorAll('.info-cloud');

  buttons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target');
      const targetCloud = document.getElementById(targetId || '');

      if (targetCloud) {
        clouds.forEach(c => {
          if (c !== targetCloud) c.classList.add('opacity-0', 'pointer-events-none', 'translate-x-4');
        });
        targetCloud.classList.toggle('opacity-0');
        targetCloud.classList.toggle('pointer-events-none');
        targetCloud.classList.toggle('translate-x-4');
      }
    });
  });

  document.addEventListener('click', () => {
    clouds.forEach(c => c.classList.add('opacity-0', 'pointer-events-none', 'translate-x-4'));
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

</style>